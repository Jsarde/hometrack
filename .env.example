# HomeTrack environment configuration template.
# Copy this file to .env and edit the values.
# .env is excluded from git; .env.example is committed.

# SQLAlchemy database URL.
# Default (SQLite, XDG path): leave unset to use the default.
# HOMETRACK_DB_URL=sqlite:////home/youruser/.local/share/hometrack/hometrack.db

# Set to "true" to enable debug logging and the OpenAPI docs at /docs.
HOMETRACK_DEBUG=false

# Bind address for the web server. Use 127.0.0.1 for local-only access.
HOMETRACK_HOST=127.0.0.1

# Port the web server listens on.
HOMETRACK_PORT=8080
